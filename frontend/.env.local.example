# Base URL of the FastAPI backend. Copy to .env.local for local dev.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# Optional — enables "Link AniList" login (watch-history taste + already-watched filter).
# Create a client at https://anilist.co/settings/developer with redirect URL
# http://localhost:3000, then paste its Client ID here and restart `npm run dev`.
NEXT_PUBLIC_ANILIST_CLIENT_ID=
